<%- include('../layouts/header') %>

<!-- Dashboard Header -->
<div class="dashboard-header animate-fade-in">
  <h1 class="dashboard-title">Manage Events</h1>
  <p class="dashboard-subtitle">Create events, manage lifecycles, register volunteer hours, and audit logs.</p>
</div>

<div class="split-container animate-fade-in" style="display: grid; grid-template-columns: 1.6fr 1fr; gap: 2rem; align-items: start; margin-bottom: 3rem;">
  
  <!-- Left Side: Events List -->
  <div style="display: flex; flex-direction: column; gap: 1.5rem;">
    <h2 style="font-size: 1.5rem; font-weight: 700; background: linear-gradient(to right, #ffffff, #94a3b8); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Active Events</h2>
    
    <% if (events && events.length > 0) { %>
      <div style="display: grid; grid-template-columns: 1fr; gap: 1.5rem;">
        <% events.forEach(function(event) { %>
          <div class="glass-card" style="padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem; position: relative;">
            
            <!-- Badge & Title -->
            <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem;">
              <div>
                <span class="badge" style="
                  background: <%= event.status === 'Open' ? 'var(--color-success-bg)' : (event.status === 'Draft' ? 'rgba(255,255,255,0.05)' : (event.status === 'Completed' ? 'var(--secondary-gradient)' : 'var(--color-danger-bg)')); %>;
                  color: <%= event.status === 'Open' ? 'var(--color-success)' : (event.status === 'Draft' ? 'var(--text-muted)' : (event.status === 'Completed' ? '#fff' : 'var(--color-danger)')); %>;
                  box-shadow: <%= event.status === 'Completed' ? '0 2px 8px rgba(6,182,212,0.3)' : 'none'; %>
                ">
                  <%= event.status %>
                </span>
                <h3 style="font-size: 1.25rem; font-weight: 700; margin-top: 0.5rem;"><%= event.title %></h3>
              </div>
              
              <!-- Inline Delete Form -->
              <form action="/admin/events/<%= event._id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this event? This action cannot be undone.');">
                <button type="submit" class="btn-icon btn-icon-delete" data-tooltip="Delete Event" style="background: rgba(239, 68, 68, 0.15); border-color: rgba(239, 68, 68, 0.25); color: var(--color-danger);">
                  <svg fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                    <polyline points="3 6 5 6 21 6"></polyline>
                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                  </svg>
                </button>
              </form>
            </div>

            <!-- Description -->
            <p style="color: var(--text-muted); font-size: 0.9375rem; line-height: 1.6;"><%= event.description %></p>
            
            <!-- Meta Details -->
            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; border-top: 1px solid var(--border-glass); border-bottom: 1px solid var(--border-glass); padding: 0.75rem 0; font-size: 0.875rem; color: var(--text-muted);">
              <div>
                <span style="display: block; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.25rem;">Date</span>
                <strong style="color: var(--text-main); font-weight: 600;"><%= new Date(event.date).toLocaleDateString('en-US', { dateStyle: 'medium' }) %></strong>
              </div>
              <div>
                <span style="display: block; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.25rem;">Capacity</span>
                <strong style="color: var(--text-main); font-weight: 600;"><%= event.joinedVolunteers.length %> / <%= event.capacity %></strong>
              </div>
              <div>
                <span style="display: block; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.25rem;">Joined</span>
                <strong style="color: var(--text-main); font-weight: 600;"><%= event.joinedVolunteers.length %> Volunteers</strong>
              </div>
            </div>

            <!-- Change Lifecycle Status Form -->
            <form action="/admin/events/<%= event._id %>/status" method="POST" style="display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-top: 0.5rem;">
              <span style="font-size: 0.875rem; font-weight: 600; color: var(--text-muted);">Update Status:</span>
              <div style="display: flex; gap: 0.5rem; align-items: center; flex: 1; max-width: 250px;">
                <select name="status" class="form-input" style="padding: 0.5rem; border-radius: 8px;" required>
                  <option value="Draft" <%= event.status === 'Draft' ? 'selected' : '' %>>Draft</option>
                  <option value="Open" <%= event.status === 'Open' ? 'selected' : '' %>>Open</option>
                  <option value="Closed" <%= event.status === 'Closed' ? 'selected' : '' %>>Closed</option>
                  <option value="Completed" <%= event.status === 'Completed' ? 'selected' : '' %>>Completed</option>
                </select>
                <button type="submit" class="btn-submit" style="width: auto; padding: 0.5rem 1rem; border-radius: 8px; font-size: 0.875rem; box-shadow: none;">
                  Apply
                </button>
              </div>
            </form>

          </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="glass-card" style="padding: 3rem; text-align: center;">
        <svg fill="none" stroke="var(--text-muted)" stroke-width="1.5" viewBox="0 0 24 24" style="width: 48px; height: 48px; margin: 0 auto 1rem; opacity: 0.5;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"></path>
        </svg>
        <p style="color: var(--text-muted);">No events found. Create one on the right pane!</p>
      </div>
    <% } %>
  </div>

  <!-- Right Side: Forms & Audits -->
  <div style="display: flex; flex-direction: column; gap: 2rem;">
    
    <!-- Create Event Card -->
    <div class="glass-card">
      <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1.5rem; color: var(--accent-color);">Create New Event</h2>
      <form action="/admin/events" method="POST" style="display: flex; flex-direction: column; gap: 1.25rem;">
        
        <div class="form-group floating filled" style="margin-bottom: 0;">
          <input type="text" name="title" id="title" class="form-input" required placeholder="Event Title">
          <label for="title">Event Title</label>
        </div>

        <div class="form-group floating filled" style="margin-bottom: 0;">
          <textarea name="description" id="description" class="form-input" required placeholder="Event Description" style="min-height: 80px;"></textarea>
          <label for="description">Event Description</label>
        </div>

        <div class="form-group" style="margin-bottom: 0;">
          <label class="form-label-standalone" style="font-size: 0.75rem;">Date & Time</label>
          <input type="datetime-local" name="date" class="form-input" required>
        </div>

        <div class="form-group floating filled" style="margin-bottom: 0;">
          <input type="number" name="capacity" id="capacity" class="form-input" required min="1" placeholder="Capacity (Max volunteers)">
          <label for="capacity">Capacity (Max volunteers)</label>
        </div>

        <div class="form-group" style="margin-bottom: 0;">
          <label class="form-label-standalone" style="font-size: 0.75rem;">Initial Status</label>
          <select name="status" class="form-input" required>
            <option value="Open" selected>Open</option>
            <option value="Draft">Draft</option>
          </select>
        </div>

        <button type="submit" class="btn-submit">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
          <span>Create Event</span>
        </button>
      </form>
    </div>

    <!-- Log Volunteer Hours Card -->
    <div class="glass-card">
      <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1.5rem; color: var(--color-success);">Log Volunteer Hours</h2>
      
      <% if (events && events.length > 0 && volunteers && volunteers.length > 0) { %>
        <form id="logHoursForm" action="/admin/events/<%= events[0]._id %>/hours" method="POST" style="display: flex; flex-direction: column; gap: 1.25rem;">
          
          <div class="form-group" style="margin-bottom: 0;">
            <label class="form-label-standalone" style="font-size: 0.75rem;">Select Event</label>
            <select id="logHoursEventId" class="form-input" required onchange="document.getElementById('logHoursForm').action = '/admin/events/' + this.value + '/hours';">
              <% events.forEach(function(e) { %>
                <option value="<%= e._id %>"><%= e.title %></option>
              <% }); %>
            </select>
          </div>

          <div class="form-group" style="margin-bottom: 0;">
            <label class="form-label-standalone" style="font-size: 0.75rem;">Select Volunteer</label>
            <select name="volunteerId" class="form-input" required>
              <option value="" disabled selected>Select Approved Volunteer</option>
              <% volunteers.forEach(function(v) { %>
                <% if (v.user) { %>
                  <option value="<%= v.user %>"><%= v.fullName %> (<%= v.email %>)</option>
                <% } %>
              <% }); %>
            </select>
          </div>

          <div class="form-group floating filled" style="margin-bottom: 0;">
            <input type="number" name="hoursWorked" id="hoursWorked" class="form-input" required min="0" step="0.5" placeholder="Hours Worked">
            <label for="hoursWorked">Hours Worked</label>
          </div>

          <button type="submit" class="btn-submit" style="background: var(--secondary-gradient); box-shadow: 0 4px 15px rgba(6,182,212,0.3);">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
              <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>Log Hours</span>
          </button>
        </form>
      <% } else { %>
        <p style="color: var(--text-muted); font-size: 0.875rem;">You need at least one event and one approved volunteer with a registered user account to log hours.</p>
      <% } %>
    </div>

    <!-- Audits Log Card -->
    <div class="glass-card" style="max-height: 400px; overflow-y: auto;">
      <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1rem; color: var(--text-main);">Admin Audit Logs</h2>
      <% if (audits && audits.length > 0) { %>
        <div style="display: flex; flex-direction: column; gap: 0.75rem;">
          <% audits.forEach(function(log) { %>
            <div style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-glass); border-radius: 8px; padding: 0.75rem; font-size: 0.8125rem;">
              <p style="color: var(--text-main); font-weight: 500; margin-bottom: 0.25rem;"><%= log.action %></p>
              <div style="display: flex; justify-content: space-between; align-items: center; color: var(--text-muted); font-size: 0.75rem;">
                <span>By: <%= log.performedBy ? log.performedBy.username : 'System' %></span>
                <span><%= new Date(log.timestamp).toLocaleString() %></span>
              </div>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <p style="color: var(--text-muted); font-size: 0.875rem;">No audit logs yet.</p>
      <% } %>
    </div>

  </div>
</div>

<%- include('../layouts/footer') %>
