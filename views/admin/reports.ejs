<%- include('../layouts/header') %>

<!-- Raw database payload embedded for pure JS client-side CSV downloads -->
<div id="volunteersRawData" style="display: none;"><%= allVolunteersJSON %></div>

<!-- Header and Controls -->
<div class="dashboard-header animate-fade-in" style="display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 1rem;">
  <div>
    <h1 class="dashboard-title">Reports & Analytics</h1>
    <p class="dashboard-subtitle">Visual summaries, geographic distribution, growth tracking, and exports.</p>
  </div>
  
  <!-- Export & Print Actions -->
  <div class="reports-header-actions">
    <button id="btnExportCsv" class="btn-export">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
        <polyline points="7 10 12 15 17 10"></polyline>
        <line x1="12" y1="15" x2="12" y2="3"></line>
      </svg>
      <span>Export CSV</span>
    </button>
    
    <button onclick="window.print()" class="btn-print">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
        <polyline points="6 9 6 2 18 2 18 9"></polyline>
        <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
        <rect x="6" y="14" width="12" height="8"></rect>
      </svg>
      <span>Print Report</span>
    </button>
  </div>
</div>

<!-- Layout reports widgets -->
<div class="reports-dashboard-grid animate-fade-in">
  
  <!-- Growth / Skills distribution graph -->
  <div class="glass-card">
    <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1.5rem;">Skill Set Demand</h2>
    <% if (skillAgg && skillAgg.length > 0) { %>
      <div style="position: relative; height: 280px; width: 100%;">
        <canvas id="skillsDemandChart"></canvas>
      </div>
    <% } else { %>
      <p style="color: var(--text-muted); font-size: 0.9375rem;">No skills distribution statistics yet.</p>
    <% } %>
  </div>

  <!-- City Demographics List -->
  <div class="glass-card">
    <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1.5rem;">City Demographics</h2>
    <% if (cityCount && cityCount.length > 0) { %>
      <div style="position: relative; height: 180px; width: 100%; margin-bottom: 1.5rem;">
        <canvas id="cityDemographicsChart"></canvas>
      </div>
      <div class="table-wrapper">
        <table class="glass-table">
          <thead>
            <tr>
              <th>City</th>
              <th style="text-align: right;">Volunteers Count</th>
            </tr>
          </thead>
          <tbody>
            <% cityCount.forEach(function(city) { %>
              <tr>
                <td style="font-weight: 600;"><%= city._id %></td>
                <td style="text-align: right; font-weight: 700; color: var(--accent-color);"><%= city.count %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p style="color: var(--text-muted); font-size: 0.9375rem; text-align: center; padding: 2rem 0;">No demographics metrics available yet.</p>
    <% } %>
  </div>

  <!-- Growth Tracking Section (growth over time) -->
  <div class="glass-card report-table-section">
    <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1.5rem;">Volunteer Registration Growth</h2>
    <% if (volunteerGrowth && volunteerGrowth.length > 0) { %>
      <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem; align-items: start;">
        <div style="position: relative; height: 320px; width: 100%;">
          <canvas id="growthChart"></canvas>
        </div>
        <div class="table-wrapper">
          <table class="glass-table">
            <thead>
              <tr>
                <th>Date</th>
                <th style="text-align: center;">New</th>
                <th style="text-align: right;">Total</th>
              </tr>
            </thead>
            <tbody>
              <% volunteerGrowth.forEach(function(day) { %>
                <tr>
                  <td style="font-weight: 600;"><%= new Date(day.date).toLocaleDateString('en-US', { dateStyle: 'medium' }) %></td>
                  <td style="text-align: center; color: var(--color-success); font-weight: 600;">+<%= day.daily %></td>
                  <td style="text-align: right; font-weight: 700;"><%= day.cumulative %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    <% } else { %>
      <p style="color: var(--text-muted); font-size: 0.9375rem; text-align: center; padding: 2rem 0;">No registration records to chart growth over time.</p>
    <% } %>
  </div>
</div>

<!-- Hidden element for passing data securely to client-side JS -->
<div id="reportsStatsData" style="display: none;"
     data-growth="<%= JSON.stringify(volunteerGrowth) %>"
     data-skills="<%= JSON.stringify(skillAgg) %>"
     data-cities="<%= JSON.stringify(cityCount) %>">
</div>

<!-- Chart.js and Reports Init Scripts -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Inject server-side data variables securely
    const dataContainer = document.getElementById('reportsStatsData');
    const rawVolunteerGrowth = JSON.parse(dataContainer.dataset.growth || '[]');
    const rawSkillAgg = JSON.parse(dataContainer.dataset.skills || '[]');
    const rawCityCount = JSON.parse(dataContainer.dataset.cities || '[]');

    const colors = {
      indigo: '#6366f1',
      violet: '#8b5cf6',
      blue: '#3b82f6',
      cyan: '#06b6d4',
      emerald: '#10b981',
      amber: '#f59e0b',
      rose: '#ef4444',
      textMuted: '#94a3b8',
      textMain: '#f8fafc',
      borderGlass: 'rgba(255, 255, 255, 0.08)'
    };

    // Global Chart.js defaults config
    Chart.defaults.color = colors.textMuted;
    Chart.defaults.font.family = "'Inter', -apple-system, sans-serif";
    Chart.defaults.font.size = 11;
    Chart.defaults.font.weight = '500';

    // 1. Growth Line Chart
    if (rawVolunteerGrowth && rawVolunteerGrowth.length > 0) {
      const growthCtx = document.getElementById('growthChart').getContext('2d');
      const dates = rawVolunteerGrowth.map(d => {
        return new Date(d.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
      });
      const dailyData = rawVolunteerGrowth.map(d => d.daily);
      const cumulativeData = rawVolunteerGrowth.map(d => d.cumulative);

      new Chart(growthCtx, {
        type: 'line',
        data: {
          labels: dates,
          datasets: [
            {
              label: 'Cumulative Registrations',
              data: cumulativeData,
              borderColor: colors.indigo,
              backgroundColor: 'rgba(99, 102, 241, 0.05)',
              borderWidth: 3,
              fill: true,
              tension: 0.3,
              yAxisID: 'y'
            },
            {
              label: 'Daily Registrations',
              data: dailyData,
              type: 'bar',
              backgroundColor: colors.cyan,
              borderRadius: 3,
              barThickness: 10,
              yAxisID: 'yDaily'
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: 'top',
              labels: { color: colors.textMuted, padding: 10 }
            },
            tooltip: {
              backgroundColor: 'rgba(15, 23, 42, 0.95)',
              titleColor: colors.textMain,
              bodyColor: colors.textMain,
              borderColor: colors.borderGlass,
              borderWidth: 1,
              padding: 10,
              cornerRadius: 8
            }
          },
          scales: {
            x: {
              grid: { color: 'rgba(255, 255, 255, 0.03)', drawBorder: false },
              ticks: { color: colors.textMuted }
            },
            y: {
              position: 'right',
              grid: { color: 'rgba(255, 255, 255, 0.04)', drawBorder: false },
              ticks: { precision: 0, color: colors.textMuted },
              title: { display: true, text: 'Cumulative Total', color: colors.textMuted }
            },
            yDaily: {
              position: 'left',
              grid: { display: false, drawBorder: false },
              ticks: { precision: 0, color: colors.textMuted },
              title: { display: true, text: 'Daily Registrations', color: colors.textMuted }
            }
          }
        }
      });
    }

    // 2. Skills Demand Chart (polar area)
    if (rawSkillAgg && rawSkillAgg.length > 0) {
      const skillsCtx = document.getElementById('skillsDemandChart').getContext('2d');
      const skillColorsMap = {
        'Teaching': colors.indigo,
        'Medical': colors.emerald,
        'Tech': colors.blue,
        'Construction': colors.amber,
        'Cooking': colors.rose,
        'Logistics': colors.violet
      };
      
      const skillLabels = rawSkillAgg.map(s => s._id);
      const skillCounts = rawSkillAgg.map(s => s.count);
      const skillColors = skillLabels.map(label => skillColorsMap[label] || colors.indigo);

      new Chart(skillsCtx, {
        type: 'polarArea',
        data: {
          labels: skillLabels,
          datasets: [{
            data: skillCounts,
            backgroundColor: skillColors.map(c => c + 'cc'), // add opacity
            borderWidth: 0
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: 'right',
              labels: { color: colors.textMuted, boxWidth: 12 }
            },
            tooltip: {
              backgroundColor: 'rgba(15, 23, 42, 0.95)',
              titleColor: colors.textMain,
              bodyColor: colors.textMain,
              borderColor: colors.borderGlass,
              borderWidth: 1
            }
          },
          scales: {
            r: {
              grid: { color: 'rgba(255, 255, 255, 0.05)' },
              angleLines: { color: 'rgba(255, 255, 255, 0.05)' },
              ticks: { display: false }
            }
          }
        }
      });
    }

    // 3. City Demographics Chart (Doughnut)
    if (rawCityCount && rawCityCount.length > 0) {
      const cityCtx = document.getElementById('cityDemographicsChart').getContext('2d');
      const cityLabels = rawCityCount.map(c => c._id);
      const cityCounts = rawCityCount.map(c => c.count);
      
      const cityColors = [
        colors.cyan,
        colors.emerald,
        colors.indigo,
        colors.amber,
        colors.violet,
        colors.rose
      ];

      new Chart(cityCtx, {
        type: 'doughnut',
        data: {
          labels: cityLabels,
          datasets: [{
            data: cityCounts,
            backgroundColor: cityColors,
            borderWidth: 0
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: 'right',
              labels: { color: colors.textMuted, boxWidth: 10, padding: 8 }
            },
            tooltip: {
              backgroundColor: 'rgba(15, 23, 42, 0.95)',
              titleColor: colors.textMain,
              bodyColor: colors.textMain,
              borderColor: colors.borderGlass,
              borderWidth: 1
            }
          },
          cutout: '65%'
        }
      });
    }
  });
</script>

<%- include('../layouts/footer') %>
