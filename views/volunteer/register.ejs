<%- include('../partials/head') %>

<!-- Public Registration Header & Outer Frame -->
<div class="public-registration-container">
  
  <div class="public-header">
    <div class="public-logo">
      <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
        <circle cx="9" cy="7" r="4"></circle>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
      </svg>
      <span>VOLUNTEER HUB</span>
    </div>
    <h1 style="font-size: 2rem; font-weight: 800; margin-bottom: 0.5rem;">Join Our Mission</h1>
    <p class="public-subtitle">Make an impact. Register today to contribute your skills and time to meaningful community causes.</p>
  </div>

  <!-- Form Multi-Step Progress Bar -->
  <div class="step-progressbar-container">
    <div id="stepProgressLine" class="step-progress-line"></div>
    
    <div class="step-node active">
      1
      <span class="step-label">Personal Profile</span>
    </div>
    <div class="step-node">
      2
      <span class="step-label">Skills & Background</span>
    </div>
  </div>

  <!-- Flash Messaging Overlays -->
  <% if (success_msg && success_msg.length > 0) { %>
    <div class="flash-message flash-message-success">
      <span class="flash-message-content"><%= success_msg %></span>
      <button class="flash-dismiss-btn" aria-label="Dismiss message">&times;</button>
    </div>
  <% } %>
  
  <% if (error_msg && error_msg.length > 0) { %>
    <div class="flash-message flash-message-error">
      <span class="flash-message-content"><%= error_msg %></span>
      <button class="flash-dismiss-btn" aria-label="Dismiss message">&times;</button>
    </div>
  <% } %>

  <!-- Server-Side validation errors display -->
  <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
    <div class="form-errors-alert">
      <h3 style="font-size: 0.9375rem; font-weight: 700; color: #fca5a5; margin-bottom: 0.5rem;">Please resolve the following:</h3>
      <ul class="form-errors-list">
        <% errors.forEach(function(error) { %>
          <li><%= error.msg %></li>
        <% }); %>
      </ul>
    </div>
  <% } %>

  <!-- Registration Form Frame -->
  <div class="glass-card">
    <form id="volunteerRegForm" action="/volunteer/register" method="POST">
      
      <!-- STEP 1: Personal Profile Info -->
      <div class="form-step active">
        <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-glass); padding-bottom: 0.5rem; color: var(--accent-color);">Personal Information</h2>
        
        <div class="form-grid">
          <!-- Full Name -->
          <div class="form-group floating validation-wrapper">
            <input type="text" name="fullName" id="fullName" class="form-input" required value="<%= typeof oldInput !== 'undefined' && oldInput.fullName ? oldInput.fullName : '' %>">
            <label for="fullName">Full Name</label>
            <!-- Valid Check -->
            <svg class="validation-icon validation-icon-valid" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <!-- Invalid X -->
            <svg class="validation-icon validation-icon-invalid" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </div>

          <!-- Email Address -->
          <div class="form-group floating validation-wrapper">
            <input type="email" name="email" id="email" class="form-input" required value="<%= typeof oldInput !== 'undefined' && oldInput.email ? oldInput.email : '' %>">
            <label for="email">Email Address</label>
            <svg class="validation-icon validation-icon-valid" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <svg class="validation-icon validation-icon-invalid" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </div>

          <!-- Phone Number -->
          <div class="form-group floating validation-wrapper">
            <input type="tel" name="phone" id="phone" class="form-input" required value="<%= typeof oldInput !== 'undefined' && oldInput.phone ? oldInput.phone : '' %>">
            <label for="phone">Phone Number</label>
            <svg class="validation-icon validation-icon-valid" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <svg class="validation-icon validation-icon-invalid" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </div>

          <!-- Age Input -->
          <div class="form-group floating validation-wrapper">
            <input type="number" name="age" id="age" min="1" max="120" class="form-input" required value="<%= typeof oldInput !== 'undefined' && oldInput.age ? oldInput.age : '' %>">
            <label for="age">Age</label>
            <svg class="validation-icon validation-icon-valid" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <svg class="validation-icon validation-icon-invalid" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </div>

          <!-- Gender Select -->
          <div class="form-group validation-wrapper">
            <select name="gender" id="gender" class="form-input" required>
              <option value="" disabled <%= typeof oldInput === 'undefined' || !oldInput.gender ? 'selected' : '' %>>Select Gender</option>
              <option value="Male" <%= typeof oldInput !== 'undefined' && oldInput.gender === 'Male' ? 'selected' : '' %>>Male</option>
              <option value="Female" <%= typeof oldInput !== 'undefined' && oldInput.gender === 'Female' ? 'selected' : '' %>>Female</option>
              <option value="Other" <%= typeof oldInput !== 'undefined' && oldInput.gender === 'Other' ? 'selected' : '' %>>Other</option>
            </select>
          </div>

          <!-- City Input -->
          <div class="form-group floating validation-wrapper">
            <input type="text" name="city" id="city" class="form-input" required value="<%= typeof oldInput !== 'undefined' && oldInput.city ? oldInput.city : '' %>">
            <label for="city">City</label>
            <svg class="validation-icon validation-icon-valid" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <svg class="validation-icon validation-icon-invalid" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </div>

          <!-- Password Input -->
          <div class="form-group floating validation-wrapper">
            <input type="password" name="password" id="password" class="form-input" required minlength="6">
            <label for="password">Password (min 6 chars)</label>
            <svg class="validation-icon validation-icon-valid" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <svg class="validation-icon validation-icon-invalid" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </div>

          <!-- Confirm Password Input -->
          <div class="form-group floating validation-wrapper">
            <input type="password" name="confirmPassword" id="confirmPassword" class="form-input" required minlength="6">
            <label for="confirmPassword">Confirm Password</label>
            <svg class="validation-icon validation-icon-valid" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <svg class="validation-icon validation-icon-invalid" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </div>
        </div>

        <!-- Section Navigation Buttons -->
        <div class="form-navigation" style="justify-content: flex-end;">
          <button type="button" class="btn-submit btn-next-step" style="width: auto;">
            <span>Next Step</span>
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </button>
        </div>
      </div>

      <!-- STEP 2: Skills & Background Details -->
      <div class="form-step">
        <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1.5rem; border-bottom: 1px solid var(--border-glass); padding-bottom: 0.5rem; color: var(--accent-color);">Skills & Availability</h2>
        
        <!-- Multi-select Skills Custom Checks -->
        <div style="margin-bottom: 1.5rem;">
          <label id="skillsLabel" class="form-label-standalone">Select Areas of Skills/Interests *</label>
          <div class="skills-tags-container">
            <% skillsList.forEach(function(skill) { 
              let isChecked = false;
              if (typeof oldInput !== 'undefined' && oldInput.skills) {
                if (Array.isArray(oldInput.skills)) {
                  isChecked = oldInput.skills.includes(skill);
                } else {
                  isChecked = oldInput.skills === skill;
                }
              }
            %>
              <input type="checkbox" name="skills" value="<%= skill %>" id="skill_<%= skill %>" class="skill-tag-checkbox" <%= isChecked ? 'checked' : '' %>>
              <label for="skill_<%= skill %>" class="skill-tag-label">
                <!-- Check Icon overlay inside label -->
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 2px;">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <%= skill %>
              </label>
            <% }); %>
          </div>
        </div>

        <div class="form-grid">
          <!-- Availability Selection -->
          <div class="form-group validation-wrapper">
            <label class="form-label-standalone">Availability *</label>
            <select name="availability" id="availability" class="form-input" required>
              <option value="" disabled <%= typeof oldInput === 'undefined' || !oldInput.availability ? 'selected' : '' %>>Select Availability</option>
              <option value="Weekdays" <%= typeof oldInput !== 'undefined' && oldInput.availability === 'Weekdays' ? 'selected' : '' %>>Weekdays</option>
              <option value="Weekends" <%= typeof oldInput !== 'undefined' && oldInput.availability === 'Weekends' ? 'selected' : '' %>>Weekends</option>
              <option value="Both" <%= typeof oldInput !== 'undefined' && oldInput.availability === 'Both' ? 'selected' : '' %>>Both (Flexible)</option>
            </select>
          </div>

          <!-- Experience Level Selection -->
          <div class="form-group validation-wrapper">
            <label class="form-label-standalone">Experience Level *</label>
            <select name="experienceLevel" id="experienceLevel" class="form-input" required>
              <option value="" disabled <%= typeof oldInput === 'undefined' || !oldInput.experienceLevel ? 'selected' : '' %>>Select Experience Level</option>
              <option value="Beginner" <%= typeof oldInput !== 'undefined' && oldInput.experienceLevel === 'Beginner' ? 'selected' : '' %>>Beginner</option>
              <option value="Intermediate" <%= typeof oldInput !== 'undefined' && oldInput.experienceLevel === 'Intermediate' ? 'selected' : '' %>>Intermediate</option>
              <option value="Advanced" <%= typeof oldInput !== 'undefined' && oldInput.experienceLevel === 'Advanced' ? 'selected' : '' %>>Advanced</option>
            </select>
          </div>
          
          <!-- Emergency Contact -->
          <div class="form-group-full form-group floating validation-wrapper">
            <input type="text" name="emergencyContact" id="emergencyContact" class="form-input" required value="<%= typeof oldInput !== 'undefined' && oldInput.emergencyContact ? oldInput.emergencyContact : '' %>">
            <label for="emergencyContact">Emergency Contact (Name & Phone Number)</label>
            <svg class="validation-icon validation-icon-valid" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <svg class="validation-icon validation-icon-invalid" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </div>

          <!-- Motivation Text Area -->
          <div class="form-group-full form-group floating validation-wrapper">
            <textarea name="motivation" id="motivation" class="form-input" required><%= typeof oldInput !== 'undefined' && oldInput.motivation ? oldInput.motivation : '' %></textarea>
            <label for="motivation">Explain your motivation for volunteering with us</label>
            <svg class="validation-icon validation-icon-valid" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="top: 2rem;"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <svg class="validation-icon validation-icon-invalid" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="top: 2rem;"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </div>
        </div>

        <!-- Back and Submit Controls -->
        <div class="form-navigation">
          <button type="button" class="btn-secondary btn-prev-step">
            <span>Previous</span>
          </button>
          
          <button type="submit" class="btn-submit" style="width: auto;">
            <span>Submit Application</span>
            <div class="spinner"></div>
          </button>
        </div>
      </div>

    </form>
  </div>
  
</div>

<%- include('../partials/footer') %>
