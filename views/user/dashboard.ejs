<%- include('../layouts/header') %>

<!-- Dashboard Header -->
<div class="dashboard-header animate-fade-in">
  <h1 class="dashboard-title">Welcome, <%= volunteer.fullName %></h1>
  <p class="dashboard-subtitle">Here is your volunteer portal status overview, metrics, and alerts.</p>
</div>

<!-- Application Status Banner -->
<div class="glass-card animate-fade-in" style="margin-bottom: 2.5rem; padding: 1.5rem; border-left: 5px solid <%= 
  volunteer.status === 'Approved' ? 'var(--color-success)' : 
  (volunteer.status === 'Rejected' ? 'var(--color-danger)' : 
  (volunteer.status === 'Completed' ? '#06b6d4' : 'var(--color-warning)')); 
%>;">
  <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
    <div>
      <h3 style="font-size: 1.15rem; font-weight: 700; margin-bottom: 0.25rem;">Application Status: 
        <span class="badge badge-<%= volunteer.status.toLowerCase() %>" style="font-size: 0.875rem; margin-left: 0.5rem;">
          <%= volunteer.status %>
        </span>
      </h3>
      <p style="color: var(--text-muted); font-size: 0.875rem;">
        <% if (volunteer.status === 'Pending') { %>
          Your profile application is currently under review by administrators. We will notify you once approved.
        <% } else if (volunteer.status === 'Approved') { %>
          Congratulations! Your profile has been approved. You are eligible to browse and join active community events.
        <% } else if (volunteer.status === 'Rejected') { %>
          Unfortunately, your application does not match our current criteria. Contact support for details.
        <% } else if (volunteer.status === 'Assigned') { %>
          You have been assigned to an active community cause! Please check your upcoming events or email alerts.
        <% } else if (volunteer.status === 'Completed') { %>
          You have successfully completed your volunteering activities. Thank you for your amazing support!
        <% } %>
      </p>
    </div>
    <a href="/user/application" class="btn-submit" style="width: auto; padding: 0.5rem 1.25rem; font-size: 0.875rem; box-shadow: none;">
      Track Application Pipeline
    </a>
  </div>
</div>

<!-- Stat Cards Grid -->
<div class="stats-grid animate-fade-in" style="margin-bottom: 2.5rem;">
  
  <!-- Total Hours Worked -->
  <div class="glass-card stat-card stat-card-tech interactive">
    <div class="stat-label">Total Hours Logged</div>
    <div class="stat-value"><%= totalHours %> hrs</div>
    <div class="stat-meta">Verified contributions</div>
    <svg class="stat-icon" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"></path>
    </svg>
  </div>

  <!-- Events Attended -->
  <div class="glass-card stat-card stat-card-medical interactive">
    <div class="stat-label">Joined Events</div>
    <div class="stat-value"><%= joinedEvents.length %></div>
    <div class="stat-meta">Active & past events</div>
    <svg class="stat-icon" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 11.517 1.278l-.538.263-.03.064a1.5 1.5 0 00-.095.498v.172h1.125a.75.75 0 110 1.5H9.75a.75.75 0 010-1.5h.375v-.172a3 3 0 01.19-1.077l.03-.064-.538-.263a.75.75 0 01-.373-1.018l.04-.08a.75.75 0 011.018-.372zM12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25z"></path>
    </svg>
  </div>

</div>

<div class="split-container animate-fade-in" style="display: grid; grid-template-columns: 1.2fr 1fr; gap: 2rem; align-items: start;">
  
  <!-- Left Side: Recent Notifications -->
  <div class="glass-card" style="display: flex; flex-direction: column; gap: 1.5rem;">
    <h2 style="font-size: 1.25rem; font-weight: 700;">System Alerts & Notifications</h2>
    
    <% if (notifications && notifications.length > 0) { %>
      <div style="display: flex; flex-direction: column; gap: 1rem;">
        <% notifications.forEach(function(n) { %>
          <div style="
            background: <%= n.isRead ? 'rgba(255, 255, 255, 0.01)' : 'rgba(99, 102, 241, 0.05)' %>;
            border: 1px solid <%= n.isRead ? 'var(--border-glass)' : 'rgba(99, 102, 241, 0.2)' %>;
            border-radius: 12px;
            padding: 1rem;
            position: relative;
            transition: var(--transition-fast);
          ">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; margin-bottom: 0.5rem;">
              <h4 style="font-weight: 700; font-size: 0.9375rem; color: <%= n.isRead ? 'var(--text-main)' : 'var(--accent-color)' %>;"><%= n.title %></h4>
              <span style="font-size: 0.75rem; color: var(--text-muted);"><%= new Date(n.createdAt).toLocaleDateString() %></span>
            </div>
            
            <p style="font-size: 0.875rem; color: var(--text-muted); line-height: 1.5; margin-bottom: 0.75rem;"><%= n.message %></p>
            
            <% if (!n.isRead) { %>
              <form action="/user/notifications/<%= n._id %>/read" method="POST" style="display: inline;">
                <button type="submit" class="btn-submit" style="width: auto; padding: 0.25rem 0.75rem; font-size: 0.75rem; border-radius: 6px; box-shadow: none;">
                  Mark as Read
                </button>
              </form>
            <% } else { %>
              <span style="font-size: 0.75rem; color: var(--color-success); font-weight: 600;">✓ Read</span>
            <% } %>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <p style="color: var(--text-muted); font-size: 0.875rem;">You have no notifications yet.</p>
    <% } %>
  </div>

  <!-- Right Side: Recommended Open Events -->
  <div class="glass-card" style="display: flex; flex-direction: column; gap: 1.5rem;">
    <div style="display: flex; justify-content: space-between; align-items: center;">
      <h2 style="font-size: 1.25rem; font-weight: 700;">Open Events</h2>
      <a href="/user/events" style="font-size: 0.875rem; color: var(--accent-color); font-weight: 600;">Browse All</a>
    </div>

    <% if (openEvents && openEvents.length > 0) { %>
      <div style="display: flex; flex-direction: column; gap: 1rem;">
        <% openEvents.forEach(function(e) { %>
          <div style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-glass); border-radius: 12px; padding: 1rem; display: flex; flex-direction: column; gap: 0.5rem;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
              <h4 style="font-weight: 600; font-size: 0.9375rem;"><%= e.title %></h4>
              <span style="font-size: 0.75rem; color: var(--text-muted);"><%= e.joinedVolunteers.length %> / <%= e.capacity %> spots</span>
            </div>
            <p style="font-size: 0.8125rem; color: var(--text-muted); text-overflow: ellipsis; white-space: nowrap; overflow: hidden;"><%= e.description %></p>
            <div style="display: flex; justify-content: space-between; align-items: center; font-size: 0.75rem; margin-top: 0.25rem;">
              <span style="color: var(--accent-color); font-weight: 600;"><%= new Date(e.date).toLocaleDateString() %></span>
              
              <% if (volunteer.status === 'Approved') { %>
                <% if (e.joinedVolunteers.includes(user._id)) { %>
                  <span style="color: var(--color-success); font-weight: 600;">✓ Joined</span>
                <% } else if (e.joinedVolunteers.length >= e.capacity) { %>
                  <span style="color: var(--color-danger); font-weight: 600;">Full</span>
                <% } else { %>
                  <form action="/user/events/<%= e._id %>/join" method="POST">
                    <button type="submit" class="btn-submit" style="width: auto; padding: 0.25rem 0.5rem; font-size: 0.75rem; border-radius: 6px; box-shadow: none;">Join</button>
                  </form>
                <% } %>
              <% } else { %>
                <span style="color: var(--text-muted);">Awaiting Approval</span>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <p style="color: var(--text-muted); font-size: 0.875rem;">No open events at this time.</p>
    <% } %>
  </div>

</div>

<%- include('../layouts/footer') %>
