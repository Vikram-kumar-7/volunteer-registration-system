<%- include('../partials/head') %>

<div class="public-registration-container">
  <div class="glass-card success-card" style="border-color: rgba(239, 68, 68, 0.2);">
    
    <!-- Error Shield Icon -->
    <div class="success-icon-wrapper" style="color: var(--color-danger); border-color: var(--color-danger); background: var(--color-danger-bg);">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
      </svg>
    </div>

    <h1 class="success-title"><%= typeof message !== 'undefined' ? message : 'An Error Occurred' %></h1>
    <p class="success-desc">
      We couldn't find the page or service you were looking for. Please check the URL or click the button below to sign in or register.
    </p>

    <div style="display: flex; justify-content: center; gap: 1rem;">
      <a href="/login" class="btn-submit" style="width: auto;">
        <span>Go to Login</span>
      </a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
