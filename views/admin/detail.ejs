<%- include('../layouts/header') %>

<!-- Header and Navigation -->
<div class="dashboard-header animate-fade-in" style="margin-bottom: 2rem; display: flex; align-items: center; justify-content: space-between;">
  <div>
    <a href="/admin/volunteers" style="font-size: 0.875rem; color: var(--text-muted); display: inline-flex; align-items: center; gap: 0.25rem; margin-bottom: 0.5rem; font-weight: 500;">
      <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
      <span>Back to directory</span>
    </a>
    <h1 class="dashboard-title"><%= volunteer.fullName %></h1>
    <p class="dashboard-subtitle">Registered on <%= new Date(volunteer.createdAt).toLocaleDateString('en-US', { dateStyle: 'long' }) %></p>
  </div>

  <span class="badge badge-<%= volunteer.status.toLowerCase() %>" style="font-size: 0.9375rem; padding: 0.5rem 1.25rem;">
    <%= volunteer.status %>
  </span>
</div>

<!-- Detailed Grid Layout -->
<div class="detail-grid animate-fade-in">
  
  <!-- Left Side: Profile Details -->
  <div class="glass-card" style="display: flex; flex-direction: column; gap: 2rem;">
    
    <!-- Profile Info Section -->
    <div>
      <h2 class="detail-section-title">Personal Profile</h2>
      <ul class="detail-info-list">
        <li class="detail-info-item">
          <span class="detail-info-label">Email Address</span>
          <span class="detail-info-value"><a href="mailto:<%= volunteer.email %>" style="color: var(--accent-color); font-weight: 600;"><%= volunteer.email %></a></span>
        </li>
        <li class="detail-info-item">
          <span class="detail-info-label">Phone Number</span>
          <span class="detail-info-value"><%= volunteer.phone %></span>
        </li>
        <li class="detail-info-item">
          <span class="detail-info-label">Age</span>
          <span class="detail-info-value"><%= volunteer.age %> years old</span>
        </li>
        <li class="detail-info-item">
          <span class="detail-info-label">Gender</span>
          <span class="detail-info-value"><%= volunteer.gender %></span>
        </li>
        <li class="detail-info-item">
          <span class="detail-info-label">City Location</span>
          <span class="detail-info-value" style="font-weight: 600;"><%= volunteer.city %></span>
        </li>
        <li class="detail-info-item">
          <span class="detail-info-label">Emergency Contact</span>
          <span class="detail-info-value"><%= volunteer.emergencyContact %></span>
        </li>
      </ul>
    </div>

    <!-- Volunteering Preferences Section -->
    <div>
      <h2 class="detail-section-title">Volunteering Settings</h2>
      <ul class="detail-info-list">
        <li class="detail-info-item">
          <span class="detail-info-label">Experience Level</span>
          <span class="detail-info-value" style="font-weight: 600;"><%= volunteer.experienceLevel %></span>
        </li>
        <li class="detail-info-item">
          <span class="detail-info-label">Availability Schedule</span>
          <span class="detail-info-value"><%= volunteer.availability %></span>
        </li>
        <li class="detail-info-item">
          <span class="detail-info-label">Skills & Interests</span>
          <span class="detail-info-value">
            <div style="display: flex; flex-wrap: wrap; gap: 6px;">
              <% volunteer.skills.forEach(function(skill) { %>
                <span style="font-size: 0.8125rem; font-weight: 600; background: rgba(99, 102, 241, 0.1); border: 1px solid rgba(99, 102, 241, 0.2); color: #a5b4fc; padding: 0.25rem 0.75rem; border-radius: 9999px;">
                  <%= skill %>
                </span>
              <% }); %>
            </div>
          </span>
        </li>
      </ul>
    </div>

    <!-- Motivation Section -->
    <div>
      <h2 class="detail-section-title">Motivation & Statement</h2>
      <p style="font-size: 0.875rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;">Why do you want to volunteer?</p>
      <div class="detail-motivation-block"><%= volunteer.motivation %></div>
    </div>

  </div>

  <!-- Right Side: Actions Sidebar -->
  <div class="detail-actions-sidebar">
    
    <!-- Status Decision Card -->
    <div class="glass-card">
      <h3 style="font-size: 1.1rem; font-weight: 700; margin-bottom: 1rem; text-align: center;">Review Decisions</h3>
      <p style="font-size: 0.8125rem; color: var(--text-muted); margin-bottom: 1.5rem; text-align: center;">Set application status based on criteria fit.</p>
      
      <form action="/admin/volunteers/<%= volunteer.id %>/status" method="POST" class="status-update-form" style="display: flex; flex-direction: column; gap: 0.75rem;">
        <input type="hidden" name="status" id="statusDecision">
        
        <!-- Approve button -->
        <button type="submit" onclick="document.getElementById('statusDecision').value='Approved'" class="btn-submit" style="background: var(--color-success); box-shadow: 0 4px 15px rgba(16, 185, 129, 0.35);">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span>Approve Application</span>
        </button>

        <!-- Assign button -->
        <button type="submit" onclick="document.getElementById('statusDecision').value='Assigned'" class="btn-submit" style="background: var(--primary-gradient); box-shadow: 0 4px 15px rgba(99, 102, 241, 0.35);">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
            <circle cx="8.5" cy="7" r="4"></circle>
            <line x1="20" y1="8" x2="20" y2="14"></line>
            <line x1="23" y1="11" x2="17" y2="11"></line>
          </svg>
          <span>Assign to Cause</span>
        </button>

        <!-- Complete button -->
        <button type="submit" onclick="document.getElementById('statusDecision').value='Completed'" class="btn-submit" style="background: var(--secondary-gradient); box-shadow: 0 4px 15px rgba(6, 182, 212, 0.35);">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
          <span>Mark Completed</span>
        </button>

        <!-- Reject button -->
        <button type="submit" onclick="document.getElementById('statusDecision').value='Rejected'" class="btn-submit" style="background: var(--color-danger); box-shadow: 0 4px 15px rgba(239, 68, 68, 0.35);">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
          <span>Reject Application</span>
        </button>

        <!-- Set back to Pending option -->
        <% if (volunteer.status !== 'Pending') { %>
          <button type="submit" onclick="document.getElementById('statusDecision').value='Pending'" class="btn-secondary" style="text-align: center; justify-content: center; width: 100%;">
            <span>Reset to Pending</span>
          </button>
        <% } %>
      </form>
    </div>

    <!-- Status History Card -->
    <div class="glass-card" style="max-height: 280px; overflow-y: auto;">
      <h3 style="font-size: 1.1rem; font-weight: 700; margin-bottom: 1rem; text-align: center;">Status Transition Logs</h3>
      <% if (volunteer.history && volunteer.history.length > 0) { %>
        <div style="display: flex; flex-direction: column; gap: 0.75rem; border-left: 1px dashed var(--border-glass); padding-left: 1rem; margin-left: 0.25rem;">
          <% volunteer.history.slice().reverse().forEach(function(h) { %>
            <div style="font-size: 0.8125rem;">
              <span class="badge badge-<%= h.status.toLowerCase() %>" style="font-size: 0.625rem; padding: 0.1rem 0.4rem; margin-bottom: 0.25rem;"><%= h.status %></span>
              <p style="color: var(--text-muted); font-size: 0.75rem;"><%= new Date(h.changedAt).toLocaleString() %></p>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <p style="color: var(--text-muted); font-size: 0.8125rem; text-align: center;">No transition logs.</p>
      <% } %>
    </div>

    <!-- Administrative Settings Card -->
    <div class="glass-card" style="border-color: rgba(239, 68, 68, 0.15);">
      <h3 style="font-size: 1.1rem; font-weight: 700; margin-bottom: 0.75rem; color: #f87171;">System Actions</h3>
      <p style="font-size: 0.8125rem; color: var(--text-muted); margin-bottom: 1.5rem;">Permanently remove the profile and application records from the database. This action is irreversible.</p>
      
      <form action="/admin/volunteers/<%= volunteer.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Are you sure you want to permanently delete this volunteer record? This action cannot be undone.');">
        <button type="submit" class="btn-submit" style="background: transparent; border: 1.5px solid var(--color-danger); color: #f87171; box-shadow: none;">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" style="margin-right: 4px;">
            <polyline points="3 6 5 6 21 6"></polyline>
            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
          </svg>
          <span>Delete Profile</span>
        </button>
      </form>
    </div>

  </div>

</div>

<%- include('../layouts/footer') %>
